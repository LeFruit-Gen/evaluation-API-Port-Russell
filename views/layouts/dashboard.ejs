<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? `${title} - Port de Plaisance` : 'Port de Plaisance' %></title>
</head>
<body>
    <nav>
        <h2>Port de Plaisance</h2>

        <p><strong>Connecté :</strong> <%= currentUser.username %> (<%= currentUser.email %>)</p>

        <ul>
            <li><a href="/dashboard">Tableau de bord</a></li>
            <li><a href="/catways">Catways</a></li>
            <li><a href="/users">Utilisateurs</a></li>
        </ul>

        <form action="/users/logout" method="POST">
            <button type="submit">Déconnexion</button>
        </form>
    </nav>

    <main>
        <p><%= new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>

        <div>
            <%- body %>
        </div>
    </main>

    <% if (typeof scripts !== 'undefined') { %>
        <% scripts.forEach(function(script) { %>
            <script src="<%= script %>"></script>
        <% }); %>
    <% } %>
</body>
</html>
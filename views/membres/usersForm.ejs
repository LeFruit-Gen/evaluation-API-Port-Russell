<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= isEditing ? 'Modifier' : 'Créer' %> un utilisateur</title>
</head>
<body>
    <%- contentFor('body') %>

    <h1><%= isEditing ? 'Modifier' : 'Créer' %> un utilisateur</h1>
    <a href="/users">← Retour aux utilisateurs</a>

    <% if (message) { %>
        <p><strong><%= message %></strong></p>
    <% } %>

    <form action="/users/<%= isEditing ? user.email : '' %>" method="POST">
        <% if (isEditing) { %>
            <input type="hidden" name="_method" value="PUT">
        <% } %>

        <label for="username">Nom d'utilisateur</label><br>
        <input type="text" id="username" name="username" value="<%= user ? user.username : '' %>" required><br><br>

        <label for="email">Email</label><br>
        <input type="email" id="email" name="email" value="<%= user ? user.email : '' %>" required><br><br>

        <label for="password">Mot de passe</label><br>
        <input type="password" id="password" name="password" <%= !isEditing ? 'required' : '' %>><br>

        <button type="submit"><%= isEditing ? 'Modifier' : 'Créer' %> l'utilisateur</button>
        <a href="/users">Annuler</a>
    </form>
</body>
</html>